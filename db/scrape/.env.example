# Reddit API credentials (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME is appended to the default user agent as required by Reddit's
# API rules (platemate-scraper/0.1 by <username>). Set REDDIT_USER_AGENT to
# override the whole string instead.
REDDIT_USERNAME=
REDDIT_USER_AGENT=

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/platemate

# LLM provider API key (provider-specific env vars also checked)
LLM_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
